# MongoDB Connection String
# ใช้ MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/thai_word_game

# JWT Secret Key (ใช้ random string ยาวๆ)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Port (optional - default is 3000)
PORT=3000
